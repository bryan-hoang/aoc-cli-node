{
	"extends": ["@tsconfig/strictest", "@total-typescript/tsconfig/bundler/no-dom/library-monorepo"],
	"compilerOptions": {
		"paths": {
			"@bryan-hoang/*": ["./packages/*/src"]
		},
		"allowJs": false,
		"checkJs": false,
		"declaration": true,
		"isolatedDeclarations": true,
		"noPropertyAccessFromIndexSignature": false,
		"types": ["node", "vite-plus/test/importMeta"],
		"skipLibCheck": true,
		"esModuleInterop": true
	},
	"exclude": ["**/dist/**", "packages/aoc-cli/bin/aoc.js", "vite.config.ts"]
}
