{
	"name": "@bryan-hoang/aoc-client",
	"version": "1.0.0",
	"description": "An Advent of Code client library",
	"keywords": [],
	"homepage": "https://github.com/bryan-hoang/aoc-cli-node#readme",
	"bugs": {
		"url": "https://github.com/bryan-hoang/aoc-cli-node/issues"
	},
	"license": "MIT",
	"author": "Bryan Hoang <bryan@bryanhoang.dev> (https://bryanhoang.dev/)",
	"repository": {
		"type": "git",
		"url": "git+ssh://git@github.com/bryan-hoang/aoc-cli-node.git"
	},
	"files": [
		"dist"
	],
	"type": "module",
	"main": "./dist/index.cjs",
	"types": "./dist/index.d.cts",
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.mts",
				"default": "./dist/index.mjs"
			},
			"require": {
				"types": "./dist/index.d.cts",
				"default": "./dist/index.cjs"
			}
		}
	},
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"build": "vp pack --format cjs,esm",
		"build:docs": "automd && tsdoc --src=src/lib.ts",
		"build:stub": "vp pack --watch",
		"prepack": "vp pack --format cjs,esm",
		"test": "vp test",
		"test:attw": "attw --pack ."
	},
	"dependencies": {
		"consola": "catalog:",
		"cookie-es": "catalog:",
		"debug": "catalog:",
		"defu": "catalog:",
		"env-paths": "catalog:",
		"ofetch": "catalog:",
		"pathe": "catalog:",
		"temporal-polyfill": "catalog:",
		"turndown": "catalog:",
		"type-level-regexp": "catalog:"
	},
	"devDependencies": {
		"@arethetypeswrong/cli": "catalog:",
		"@types/debug": "catalog:",
		"@types/turndown": "catalog:",
		"vite-plus": "catalog:"
	}
}
